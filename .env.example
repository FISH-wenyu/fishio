PORT=8080
SCHEDULER_OFF=0
AUTOPILOT_OFF=0   # 1 = don't auto-refill the queue when it empties

# ── Brain selection ───────────────────────────────────────────────
# claude    = Claude Code CLI subprocess (needs `npm i -g @anthropic-ai/claude-code` + /login)
# deepseek  = DeepSeek HTTP API (needs DEEPSEEK_API_KEY, see https://platform.deepseek.com)
BRAIN_PROVIDER=claude
# Set to 1 to try the OTHER provider when the primary throws.
BRAIN_FALLBACK=0

# ── Claude Code CLI (brain when BRAIN_PROVIDER=claude or used as fallback) ──
# On Windows, set the absolute path to claude.cmd (npm global install).
# On macOS/Linux, just `claude` is usually fine.
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_MS=60000

# ── DeepSeek (brain when BRAIN_PROVIDER=deepseek or used as fallback) ──────
# Sign up + top up at https://platform.deepseek.com, generate a key (sk-...).
DEEPSEEK_API_KEY=
# deepseek-chat = V3, fast & cheap (~$0.27 per 1M input). Default.
# deepseek-reasoner = R1, smarter but slower & 5x more expensive.
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=60000
# 0.0 (deterministic) … 1.0 (balanced) … 1.5 (creative). DeepSeek docs say
# ~1.0 for general chat; lower if you want consistent answers.
DEEPSEEK_TEMPERATURE=1.0
# Override only if you're routing through a proxy / private deployment.
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# ElevenLabs TTS — free 10k chars/month at https://elevenlabs.io
ELEVENLABS_API_KEY=
# Default = Matilda. Browse more at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY=0.75
ELEVENLABS_STYLE=0.0

# OpenWeatherMap — free key at https://openweathermap.org/api
OPENWEATHER_KEY=
WEATHER_CITY=
WEATHER_LAT=
WEATHER_LON=

# ── Public tunnels (optional, only used by scripts/start-*.cmd auto-start) ──
# If you reserved a static ngrok domain at https://dashboard.ngrok.com/domains
# put it here (without https://) so the wrapper script binds the same URL on
# every boot. Leave blank to fall back to a random ngrok URL.
NGROK_DOMAIN=

# If you set USE_CLOUDFLARED=1 the NSSM service "fishio-cloudflared" will run
# a quick-tunnel — note the URL changes on every restart. For a stable URL,
# create a named tunnel (see docs/autostart.md "Named Cloudflare tunnel").
USE_CLOUDFLARED=0
USE_NGROK=0
