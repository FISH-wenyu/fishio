PORT=8080
# On Windows, set the absolute path to claude.cmd (npm global install).
# On macOS/Linux, just `claude` is usually fine.
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_MS=60000
SCHEDULER_OFF=0
AUTOPILOT_OFF=0   # 1 = don't auto-refill the queue when it empties

# ElevenLabs TTS — free 10k chars/month at https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY=0.75
ELEVENLABS_STYLE=0.0

# OpenWeatherMap — free key at https://openweathermap.org/api
OPENWEATHER_KEY=
WEATHER_CITY=
WEATHER_LAT=
WEATHER_LON=
